// TrackForge — Prisma schema
// Milestone 1 subset. See PROJECT_PLAN.md §7 for the full data model rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon/Vercel Postgres put a connection pooler in front of DATABASE_URL in
  // production; migrations need a direct (unpooled) connection instead. Both
  // point at the same local Postgres in dev (see .env.example) -- this only
  // matters once Phase 20's production database is wired up.
  directUrl = env("DIRECT_URL")
}

model Track {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")

  // Anonymous-creator model (PROJECT_PLAN.md §8, permanent as of Milestone 3 --
  // no accounts, ever). authorId is a stable per-browser id read from a cookie
  // (see lib/anonymous-id.ts), the same value across every track that browser
  // creates -- what a Phase 19 creator page groups by.
  authorId    String
  editToken   String

  // The current TrackDocument (see modules/track-format/schema.ts). Validated with Zod
  // at every read/write boundary — Prisma only guarantees it's valid JSON, not a valid document.
  document    Json

  isPublished Boolean  @default(false)

  // Discovery (Phase 17). playCount increments once per visitor Play from the
  // public track page (see api/tracks/[slug]/play) -- not incremented for the
  // owner's own in-editor test plays, so it reflects real external interest.
  playCount   Int      @default(0)
  tags        String[] @default([])

  // Denormalized from Like rows (Phase 18), same reasoning as playCount --
  // cheap to sort/index on, kept in sync inside the like-toggle transaction.
  likeCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions    TrackVersion[]
  likes       Like[]
  comments    Comment[]

  @@index([authorId])
  @@index([isPublished, createdAt])
  @@index([isPublished, playCount])
  @@index([isPublished, likeCount])
}

// One row per save. Empty of product features until Milestone 3 (version history UI),
// but capturing the trail from day one avoids a backfill later.
model TrackVersion {
  id        String   @id @default(cuid())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  document  Json
  createdAt DateTime @default(now())

  @@index([trackId])
}

// Phase 18 (anonymous engagement, no accounts -- PROJECT_PLAN.md §8). One row
// per (track, viewerId); the unique constraint IS the "one like per browser"
// rule, not application logic re-checking it.
model Like {
  id        String   @id @default(cuid())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  viewerId  String
  createdAt DateTime @default(now())

  @@unique([trackId, viewerId])
}

// Freeform display name instead of an account (§8) -- no login to gate abuse,
// so keep the body short and rely on Phase 20's rate limiting, not on this
// model, to control spam volume.
model Comment {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  displayName String
  body        String
  createdAt   DateTime @default(now())

  @@index([trackId, createdAt])
}
