# Local dev default (docker-compose.yml spins up a matching Postgres container).
# In production these point at a Neon/Vercel Postgres connection string --
# DATABASE_URL through the connection pooler (used at runtime), DIRECT_URL
# unpooled (used by `prisma migrate`). Locally there's no pooler, so both are
# the same value.
DATABASE_URL="postgresql://trackforge:trackforge@localhost:5432/trackforge"
DIRECT_URL="postgresql://trackforge:trackforge@localhost:5432/trackforge"

# Absolute base URL used for sitemap.xml, robots.txt, and Open Graph image
# generation (Phase 20) -- these need a real origin, "relative" isn't valid
# in a sitemap or an og:image meta tag. Vercel sets VERCEL_URL automatically
# per-deployment as a fallback (see src/lib/site-url.ts); set this explicitly
# once the custom domain is live so shared links point at it, not a preview URL.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Milestone 5 (Live Collaboration) -- the PartyKit room host for the
# editor's presence/live-cursors feature (see party/index.ts,
# use-presence-room.ts). Public (client connects directly via WebSocket).
# `partykit dev`'s default local port for local dev; the deployed
# `<project>.<user>.partykit.dev` host in production (see partykit.json).
NEXT_PUBLIC_PARTYKIT_HOST="127.0.0.1:1999"
